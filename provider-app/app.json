{
  "expo": {
    "name": "Provider BeHappyTalk",
    "slug": "behappytalk-provider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B76FF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.behappytalk.provider"
    },
    "android": {
      "package": "com.behappytalk.provider",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1B76FF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "provider-app",
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs photo library access to allow you to send images in chat."
        }
      ],
      "expo-font",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20",
            "compileSdkVersion": 36,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6ba25f73-c558-44d9-92b3-ccde30f44de4"
      }
    }
  }
}
